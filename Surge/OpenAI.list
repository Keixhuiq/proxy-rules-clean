DOMAIN,prodregistryv2.org             # Claude 共用
DOMAIN-SUFFIX,statsig.com             # Claude 共用
DOMAIN,statsigapi.net                 # Claude 共用
DOMAIN,events.statsigapi.net          # Claude 共用

# === D 类：Cloudflare Challenge / 风控挑战；与 Claude 共用 ===
DOMAIN,challenges.cloudflare.com      # Claude 共用

# === E 类：客服 / 支持组件；与 Claude 共用 ===
DOMAIN-SUFFIX,intercom.io             # Claude 共用
DOMAIN-SUFFIX,intercomcdn.com         # Claude 共用
DOMAIN,js.intercomcdn.com             # Claude 共用；被 intercomcdn.com 覆盖，可留作说明

# === F 类：上传、静态资源、官网 CDN / 存储兼容 ===
DOMAIN,openaiapi-site.azureedge.net
DOMAIN,openaicom.imgix.net
DOMAIN,openaicomproductionae4b.blob.core.windows.net
