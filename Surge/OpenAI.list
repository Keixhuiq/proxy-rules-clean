# NAME: OpenAI
# FORMAT: Surge rule-set (external)
# USAGE: RULE-SET, <url>, OpenAI
# NOTE: 按 OpenAI 官方 allowlist + 兼容项整理，保证企业网络/严格防火墙下完整可用

# === A 类：OpenAI / ChatGPT / Sora 核心链路，必须同 IP 出口 ===
DOMAIN-SUFFIX,openai.com
DOMAIN-SUFFIX,chatgpt.com
DOMAIN-SUFFIX,oaistatic.com
DOMAIN-SUFFIX,oaiusercontent.com
DOMAIN-SUFFIX,sora.com

# === B 类：登录 / 认证 / 企业 SSO，建议同出口 ===
# auth.openai.com / auth0.openai.com / setup.auth.openai.com 已被 openai.com 覆盖
# WorkOS 用于企业 SSO
DOMAIN-SUFFIX,workos.com
DOMAIN-SUFFIX,workoscdn.com
DOMAIN,workos.imgix.net

# === C 类：Feature Flag / 实验配置（与 Claude 共用）===
DOMAIN-SUFFIX,statsig.com
DOMAIN-SUFFIX,statsigapi.net
DOMAIN-SUFFIX,featuregates.org
DOMAIN-SUFFIX,featureassets.org
DOMAIN-SUFFIX,prodregistryv2.org

# === D 类：Cloudflare Challenge / 风控挑战（与 Claude 共用）===
DOMAIN,challenges.cloudflare.com

# === E 类:客服/支持组件（与 Claude 共用）===
DOMAIN-SUFFIX,intercom.io
DOMAIN-SUFFIX,intercomcdn.com

# === F 类：上传、静态资源、官网 CDN / 存储（OpenAI 官方 allowlist）===
DOMAIN,openaiapi-site.azureedge.net
DOMAIN,openaicom.imgix.net
DOMAIN,openaicomproductionae4b.blob.core.windows.net
DOMAIN,openaicom-api-bdcpf8c6d2e9atf6.z01.azurefd.net
DOMAIN,production-openaicom-storage.azureedge.net
DOMAIN,cdn.openaimerge.com

# === G 类：遥测 / 错误上报（OpenAI 官方 allowlist）===
DOMAIN,rum.browser-intake-datadoghq.com
DOMAIN,o207216.ingest.sentry.io
DOMAIN,o33249.ingest.sentry.io

# === H 类：支付 / 邮件 / iOS 推送 ===
# 支付（订阅 Plus 时使用）
DOMAIN,js.stripe.com
# SendGrid 邮件链接追踪
DOMAIN-SUFFIX,ct.sendgrid.net
# Apple 推送相关（iOS App 使用）
DOMAIN,humb.apple.com

# === I 类：Arkose 人机验证（第三方规则常见，OpenAI 实际使用）===
DOMAIN,openai-api.arkoselabs.com
DOMAIN,client-api.arkoselabs.com
